#!/usr/bin/env bash
# pkgmanager — interactive package manager with fzf

set -euo pipefail

# ── Colors ────────────────────────────────────────────────────────────────────
RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
CYAN='\033[0;36m'
BOLD='\033[1m'
RESET='\033[0m'

NAV_HINT="↩ select  ⌫ back  ESC quit"
FZF_ACTION="select"
FZF_RESULT=""
AFTER_ACTION="stay"

# ── fzf wrapper with back/quit navigation ────────────────────────────────────
# Called directly (never as last command of a pipe) so globals propagate.
# $FZF_ACTION : "select" | "back" | "quit"
# $FZF_RESULT : selected text (empty on back/quit)
fzf_nav() {
	local nav_file ec back transform
	nav_file=$(mktemp)
	ec=0
	back="execute-silent(echo back > ${nav_file})+abort"
	transform="if [ -z \"\${FZF_QUERY}\" ]; then echo '${back}'; else echo 'backward-delete-char'; fi"
	FZF_RESULT=$(fzf \
		--bind "bspace:transform{${transform}}" \
		--bind "ctrl-h:transform{${transform}}" \
		"$@") || ec=$?

	FZF_ACTION="select"
	if [[ -s "$nav_file" ]]; then
		FZF_ACTION="back"
		FZF_RESULT=""
	elif [[ $ec -ne 0 ]]; then
		FZF_ACTION="quit"
		FZF_RESULT=""
	fi
	rm -f "$nav_file"
}

# ── Package source ────────────────────────────────────────────────────────────
get_packages() {
	case "$1" in
	all) pacman -Qq ;;
	explicit) pacman -Qqe ;;
	orphans) pacman -Qqtd ;;
	foreign) pacman -Qqm ;;
	updates) checkupdates ;;
	esac
}

# ── Package preview (exported for fzf --preview subprocess) ──────────────────
preview_pkg() {
	local pkg="$1"
	echo -e "${BOLD}━━━ Info ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${RESET}"
	pacman -Qi "$pkg" 2>/dev/null || pacman -Si "$pkg" 2>/dev/null
	echo -e "\n${BOLD}━━━ Installed files (first 10) ━━━━━━━━━━━━━━━━━━━━━━━${RESET}"
	pacman -Ql "$pkg" 2>/dev/null | head -10
	echo -e "\n${BOLD}━━━ Dependencies ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${RESET}"
	pactree -d1 "$pkg" 2>/dev/null || echo "(pactree not available)"
	echo -e "\n${BOLD}━━━ Required by ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${RESET}"
	pactree -r -d1 "$pkg" 2>/dev/null || echo "(none)"
}
export -f preview_pkg
export RED YELLOW GREEN CYAN BOLD RESET

# ── Screen: source selection ──────────────────────────────────────────────────
screen_source() {
	fzf_nav \
		--no-multi --layout=reverse \
		--prompt="Source > " \
		--header="$NAV_HINT" \
		--preview-window=hidden \
		< <(printf '%s\n' \
			"1) All installed packages" \
			"2) Explicitly installed packages" \
			"3) Orphan packages (unused dependencies)" \
			"4) Foreign packages (AUR / manual)" \
			"5) Available updates (checkupdates)" \
			"6) Package finder (pacman -Fq)")
	[[ "$FZF_ACTION" != "select" ]] && return
	local num
	num=$(printf '%s' "$FZF_RESULT" | grep -o '^[0-9]' || true)
	case "$num" in
	1) FZF_RESULT="all" ;; 2) FZF_RESULT="explicit" ;;
	3) FZF_RESULT="orphans" ;; 4) FZF_RESULT="foreign" ;;
	5) FZF_RESULT="updates" ;; 6) FZF_RESULT="pkgfinder" ;;
	*) FZF_RESULT="" ;;
	esac
}

# ── Screen: package selection ─────────────────────────────────────────────────
# Supports multi-field lines (e.g. updates: "pkg old -> new") via --delimiter.
# $FZF_RESULT is set to space-separated package names (first field of each selection).
screen_packages() {
	fzf_nav \
		--ansi \
		--multi --layout=reverse \
		--prompt="Package > " \
		--header="TAB: multi-select  |  $NAV_HINT" \
		--delimiter=' ' \
		--preview='bash -c "preview_pkg {1}" 2>/dev/null' \
		--preview-window='right:55%:wrap' \
		< <(printf '%s\n' "$1")
	[[ "$FZF_ACTION" != "select" || -z "$FZF_RESULT" ]] && return
	# Extract package name (first field) to handle "pkg old -> new" format from updates
	FZF_RESULT=$(printf '%s' "$FZF_RESULT" | awk '{print $1}' | tr '\n' ' ' | sed 's/ $//')
}

# ── Screen: sync file database ───────────────────────────────────────────────
screen_sync_db() {
	fzf_nav \
		--no-multi --layout=reverse \
		--prompt="Sync db? > " \
		--header="Sync the file database before searching?  |  $NAV_HINT" \
		--preview-window=hidden \
		< <(printf '%s\n' "Yes – sudo pacman -Fy" "No  – use existing db")
	[[ "$FZF_ACTION" != "select" ]] && return
	if [[ "$FZF_RESULT" == "Yes"* ]]; then
		sudo pacman -Fy
		printf '\nPress Enter to continue…'
		read -r _
	fi
}

# ── Screen: package finder ────────────────────────────────────────────────────
# Live search: user types a command/file name, list reloads via pacman -Fq.
screen_pkgfinder() {
	local reload
	reload='[ -z "{q}" ] && true || (inst=$(pacman -Qq 2>/dev/null); pacman -Fq {q} 2>/dev/null | awk -F/ "{print \$NF}" | sort -u | while IFS= read -r p; do if echo "$inst" | grep -qx "$p"; then printf "\033[32m✓ %s\033[0m\n" "$p"; else printf "  %s\n" "$p"; fi; done || true)'
	fzf_nav \
		--ansi \
		--multi --layout=reverse \
		--prompt="Command/file > " \
		--header=$'Find package by command or file \nTAB: multi-select  |  '"$NAV_HINT" \
		--disabled \
		--preview='bash -c "preview_pkg {-1}" 2>/dev/null' \
		--preview-window='right:55%:wrap' \
		--bind "change:reload:${reload}" \
		< <(true)
	[[ "$FZF_ACTION" != "select" || -z "$FZF_RESULT" ]] && return
	FZF_RESULT=$(printf '%s' "$FZF_RESULT" | awk '{print $NF}' | tr '\n' ' ' | sed 's/ $//')
}

# ── Screen: action selection ──────────────────────────────────────────────────
screen_action() {
	fzf_nav \
		--no-multi --layout=reverse \
		--prompt="Action > " \
		--header="$1  |  $NAV_HINT" \
		--preview-window=hidden \
		< <(printf '%s\n' \
			"1) Detailed info              (pacman -Qi)" \
			"2) File list                  (pacman -Ql)" \
			"3) Dependency tree            (pactree)" \
			"4) Reverse tree (required by) (pactree -r)" \
			"5) Uninstall                  (pacman -Rns)" \
			"6) Uninstall + cascade        (pacman -Rcns)" \
			"7) Mark as dependency         (pacman -D --asdeps)" \
			"8) Mark as explicit           (pacman -D --asexplicit)" \
			"9) Install / Upgrade          (pacman -S)")
	[[ "$FZF_ACTION" != "select" ]] && return
	local num
	num=$(printf '%s' "$FZF_RESULT" | grep -o '^[0-9]' || true)
	FZF_RESULT="$num"
}

# ── Dep/reverse-dep inner navigation loop ────────────────────────────────────
_dep_action_loop() {
	local dep_list="$1" inner_pkgs
	while true; do
		screen_packages "$dep_list"
		case "$FZF_ACTION" in back | quit) break ;; esac
		[[ -z "$FZF_RESULT" ]] && continue
		inner_pkgs="$FZF_RESULT"
		screen_action "[$inner_pkgs]"
		case "$FZF_ACTION" in
		back) continue ;;
		quit) break ;;
		esac
		[[ -z "$FZF_RESULT" ]] && continue
		execute_action "$FZF_RESULT" "$inner_pkgs"
	done
	AFTER_ACTION="stay"
}

# ── Execute action ────────────────────────────────────────────────────────────
execute_action() {
	local id="$1" pkgs="$2"
	AFTER_ACTION="stay"
	case "$id" in
	1) fzf --no-multi --layout=reverse --preview-window=hidden \
		< <(pacman -Qi $pkgs 2>/dev/null || pacman -Si $pkgs) >/dev/null || true ;;
	2) fzf --no-multi --layout=reverse --preview-window=hidden \
		< <(pacman -Ql $pkgs) >/dev/null || true ;;
	3)
		local dep_list
		dep_list=$(for p in $pkgs; do
			{ pactree -u "$p" 2>/dev/null || true; } | tail -n +2
		done | sort -u)
		if [[ -z "$dep_list" ]]; then
			fzf --no-multi --layout=reverse --preview-window=hidden \
				< <(printf '  (no dependencies)\n') >/dev/null || true
		else
			_dep_action_loop "$dep_list"
		fi
		;;
	4)
		local rev_list
		rev_list=$(for p in $pkgs; do
			{ pactree -r -u "$p" 2>/dev/null || true; } | tail -n +2
		done | sort -u)
		if [[ -z "$rev_list" ]]; then
			fzf --no-multi --layout=reverse --preview-window=hidden \
				< <(printf '  (no reverse dependencies)\n') >/dev/null || true
		else
			_dep_action_loop "$rev_list"
		fi
		;;
	5) if fzf --no-multi --layout=reverse \
		--prompt="↩ confirm  ESC cancel > " --preview-window=hidden >/dev/null \
		< <(printf '%s\n' "Uninstall with pacman -Rns:" "" $pkgs); then
		if sudo pacman -Rns $pkgs; then
			echo -e "${GREEN}✓ Uninstalled.${RESET}"
			AFTER_ACTION="refresh"
		fi
	fi ;;
	6) if fzf --no-multi --layout=reverse \
		--prompt="↩ confirm  ESC cancel > " --preview-window=hidden >/dev/null \
		< <(printf '%s\n' "Cascade uninstall (pacman -Rcns):" \
			"⚠  Also removes dependent packages" "" $pkgs); then
		if sudo pacman -Rcns $pkgs; then
			echo -e "${GREEN}✓ Cascade uninstalled.${RESET}"
			AFTER_ACTION="refresh"
		fi
	fi ;;
	7) sudo pacman -D --asdeps $pkgs && echo -e "${GREEN}✓ Marked as dependencies.${RESET}" || true ;;
	8) sudo pacman -D --asexplicit $pkgs && echo -e "${GREEN}✓ Marked as explicit.${RESET}" || true ;;
	9) if fzf --no-multi --layout=reverse \
		--prompt="↩ confirm  ESC cancel > " --preview-window=hidden >/dev/null \
		< <(printf '%s\n' "Install / Upgrade with pacman -S:" "" $pkgs); then
		if sudo pacman -S $pkgs; then
			echo -e "${GREEN}✓ Done.${RESET}"
			AFTER_ACTION="refresh"
		fi
	fi ;;
	esac
}

# ── Main ──────────────────────────────────────────────────────────────────────
main() {
	local screen="source"
	local source_key="" pkg_list="" pkgs_inline=""

	while true; do
		case "$screen" in
		source)
			screen_source
			case "$FZF_ACTION" in back | quit) exit 0 ;; esac
			[[ -z "$FZF_RESULT" ]] && continue
			source_key="$FZF_RESULT"
			if [[ "$source_key" == "pkgfinder" ]]; then
				screen_sync_db
				case "$FZF_ACTION" in
				back | quit) continue ;;
				esac
				screen="pkgfinder"
				continue
			fi
			pkg_list=$(get_packages "$source_key") || true
			if [[ -z "$pkg_list" ]]; then
				fzf --no-multi --layout=reverse --prompt="" --preview-window=hidden \
					--header="↩ / ESC: back to sources" \
					< <(echo "  (no packages in this category)") >/dev/null || true
				continue
			fi
			screen="packages"
			;;

		packages)
			screen_packages "$pkg_list"
			case "$FZF_ACTION" in
			back)
				screen="source"
				continue
				;;
			quit) exit 0 ;;
			esac
			[[ -z "$FZF_RESULT" ]] && continue
			pkgs_inline="$FZF_RESULT"
			screen="action"
			;;

		pkgfinder)
			screen_pkgfinder
			case "$FZF_ACTION" in
			back)
				screen="source"
				continue
				;;
			quit) exit 0 ;;
			esac
			[[ -z "$FZF_RESULT" ]] && continue
			pkgs_inline="$FZF_RESULT"
			screen="action"
			;;

		action)
			screen_action "[$pkgs_inline]"
			case "$FZF_ACTION" in
			back)
				if [[ "$source_key" == "pkgfinder" ]]; then
					screen="pkgfinder"
				else
					screen="packages"
				fi
				continue
				;;
			quit) exit 0 ;;
			esac
			[[ -z "$FZF_RESULT" ]] && continue
			execute_action "$FZF_RESULT" "$pkgs_inline"
			if [[ "$AFTER_ACTION" == "refresh" ]]; then
				if [[ "$source_key" == "pkgfinder" ]]; then
					screen="pkgfinder"
				else
					pkg_list=$(get_packages "$source_key") || true
					screen="packages"
				fi
			fi
			;;
		esac
	done
}

main
