#!/usr/bin/env bash

set -euo pipefail
IFS=$'\n\t'

# === GLOBALS ===

SCRIPT_NAME="$(basename "$0")"
DEPENDENCIES=(git fzf)

LOG_OPTS=()
SHOW_OPTS=()
REFS=()
PATHS=()
SHOW_STR=""

# === FUNCTIONS ===

usage() {
	cat >&2 <<EOF
Usage: ${SCRIPT_NAME} [LOG_OPTS] [SHOW_OPTS] [REF[..REF]] [-- <path>...]

Arguments:
  REF              Branch, tag, or commit range (e.g. main, v1.0, HEAD~5..HEAD)
  -- <path>...     Restrict history to these paths

Log filtering options (-> git log):
  -a, --all               Include all branches/tags/remotes
      --no-merges         Exclude merge commits
      --author=<pattern>  Filter by author name/email
      --grep=<pattern>    Filter by commit message content
      --since=<date>      Show commits newer than date
      --until=<date>      Show commits older than date

Preview options (-> git show in fzf):
  -s, --stat              Show file change statistics
  -q, --no-patch          Show commit message only, no diff
  -w, --word-diff         Word-level diff
  -n, --name-only         Show only names of changed files
      --name-status       Show names and status (A/M/D)

General:
  -h, --help              Show this help and exit

fzf keybinds:
  Enter    Open in pager
  ctrl-y   Copy hash to clipboard + notify
  ctrl-r   Interactive rebase from this commit (full todo)
  ctrl-e   Edit commit content (pauses rebase, amend then git rebase --continue)
  ctrl-w   Reword commit message only
  ctrl-o   Checkout this commit/branch
  ctrl-b   Create new branch from this commit
  ctrl-x   Cherry-pick onto current branch
  ctrl-u   Reset --soft to this commit
  ctrl-p   Toggle preview window
EOF
}

check_dependencies() {
	local cmd
	for cmd in "${DEPENDENCIES[@]}"; do
		if ! command -v "$cmd" &>/dev/null; then
			printf "Error: required tool '%s' is not installed or not in PATH\n" "$cmd" >&2
			exit 1
		fi
	done
}

detect_clipboard_cmd() {
	if command -v wl-copy &>/dev/null; then
		printf "wl-copy"
	elif command -v xclip &>/dev/null; then
		printf "xclip -selection clipboard"
	elif command -v xsel &>/dev/null; then
		printf "xsel --clipboard --input"
	else
		printf ""
	fi
}

check_dirty_and_stash() {
	[[ -z "$(git status --porcelain)" ]] && return 0

	printf "Uncommitted changes detected:\n"
	printf "  [s] Auto stash\n"
	printf "  [m] Stash with custom message\n"
	printf "  [n] Cancel\n"
	local choice
	read -r -n 1 -p "Choice [s/m/n]: " choice
	printf "\n"

	case "$choice" in
		s | S) git stash push -m "ghist: auto-stash" ;;
		m | M)
			local msg
			read -r -p "Stash message: " msg
			git stash push -m "$msg"
			;;
		*)
			printf "Operation cancelled.\n"
			return 1
			;;
	esac
}

action_pager() {
	local hash="$1"
	# shellcheck disable=SC2086
	git show --color=always "$hash" | ${PAGER:-less} ${LESS:-}
}

action_copy() {
	local hash="$1"
	local clipboard_cmd
	clipboard_cmd="$(detect_clipboard_cmd)"
	if [[ -n "$clipboard_cmd" ]]; then
		# shellcheck disable=SC2086
		printf '%s' "$hash" | $clipboard_cmd
		notify-send "ghist" "Hash $hash copied to clipboard" 2>/dev/null || true
	else
		printf "No clipboard tool available (install wl-copy or xclip)\n" >&2
	fi
}

action_rebase() {
	local hash="$1"
	check_dirty_and_stash || return
	git rebase -i "${hash}^"
}

action_edit() {
	local hash="$1"
	check_dirty_and_stash || return
	GIT_SEQUENCE_EDITOR="sed -i '0,/^pick/s/^pick/edit/'" git rebase -i "${hash}^"
}

action_reword() {
	local hash="$1"
	check_dirty_and_stash || return
	GIT_SEQUENCE_EDITOR="sed -i '0,/^pick/s/^pick/reword/'" git rebase -i "${hash}^"
}

action_checkout() {
	local hash="$1"
	check_dirty_and_stash || return
	git checkout "$hash"
}

action_branch() {
	local hash="$1"
	local name
	check_dirty_and_stash || return
	read -r -p "Branch name: " name
	[[ -z "$name" ]] && { printf "Cancelled.\n"; return; }
	git checkout -b "$name" "$hash"
}

action_cherry_pick() {
	local hash="$1"
	check_dirty_and_stash || return
	git cherry-pick "$hash"
}

action_reset_soft() {
	local hash="$1"
	local choice
	printf "Reset --soft to %s? All commits after this will be unstaged. [y/N] " "$hash"
	read -r -n 1 choice
	printf "\n"
	[[ "$choice" =~ ^[Yy]$ ]] || { printf "Cancelled.\n"; return; }
	git reset --soft "$hash"
}

run_fzf() {
	if [[ ${#SHOW_OPTS[@]} -gt 0 ]]; then
		SHOW_STR="${SHOW_OPTS[*]}"
	fi

	local git_args=()
	if [[ ${#LOG_OPTS[@]} -gt 0 ]]; then git_args+=("${LOG_OPTS[@]}"); fi
	if [[ ${#REFS[@]} -gt 0 ]]; then git_args+=("${REFS[@]}"); fi
	if [[ ${#PATHS[@]} -gt 0 ]]; then git_args+=("--" "${PATHS[@]}"); fi

	local result key hash
	result=$(git log --color=always \
		--pretty=format:"%C(auto)%h %C(blue)%an %C(green)%ad%Creset %s" \
		--date-order --date=human \
		"${git_args[@]}" \
		| fzf --ansi --no-sort \
			--preview "git show --color=always $SHOW_STR {1}" \
			--preview-window='right:70%' \
			--expect=enter,ctrl-y,ctrl-r,ctrl-e,ctrl-w,ctrl-o,ctrl-b,ctrl-x,ctrl-u \
			--bind "ctrl-p:toggle-preview"
	) || true

	[[ -z "$result" ]] && return
	key=$(head -1 <<< "$result")
	hash=$(tail -1 <<< "$result" | awk '{print $1}')
	[[ -z "$hash" ]] && return

	case "$key" in
		enter | "") action_pager       "$hash" ;;
		ctrl-y)     action_copy        "$hash" ;;
		ctrl-r)     action_rebase      "$hash" ;;
		ctrl-e)     action_edit        "$hash" ;;
		ctrl-w)     action_reword      "$hash" ;;
		ctrl-o)     action_checkout    "$hash" ;;
		ctrl-b)     action_branch      "$hash" ;;
		ctrl-x)     action_cherry_pick "$hash" ;;
		ctrl-u)     action_reset_soft  "$hash" ;;
	esac
}

main() {
	while [[ $# -gt 0 ]]; do
		case "$1" in
		--)
			shift
			PATHS=("$@")
			break
			;;
		-h | --help)
			usage
			exit 0
			;;
		-a | --all)
			LOG_OPTS+=("--all")
			;;
		--no-merges)
			LOG_OPTS+=("--no-merges")
			;;
		--author=* | --grep=* | --since=* | --until=*)
			LOG_OPTS+=("$1")
			;;
		--author | --grep | --since | --until)
			if [[ $# -lt 2 ]]; then
				printf "Error: '%s' requires an argument\n" "$1" >&2
				usage
				exit 1
			fi
			LOG_OPTS+=("$1" "$2")
			shift
			;;
		-s | --stat)
			SHOW_OPTS+=("--stat")
			;;
		-q | --no-patch)
			SHOW_OPTS+=("--no-patch")
			;;
		-w | --word-diff)
			SHOW_OPTS+=("--word-diff")
			;;
		-n | --name-only)
			SHOW_OPTS+=("--name-only")
			;;
		--name-status)
			SHOW_OPTS+=("--name-status")
			;;
		-*)
			printf "Error: unknown option '%s'\n" "$1" >&2
			usage
			exit 1
			;;
		*)
			REFS+=("$1")
			;;
		esac
		shift
	done

	check_dependencies

	if ! git rev-parse --git-dir &>/dev/null; then
		printf "Error: not a git repository\n" >&2
		exit 1
	fi

	run_fzf
}

if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
	main "$@"
	exit 0
fi
