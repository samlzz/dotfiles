# SSH - jamais les clés privées
packages/ssh/.ssh/id_*
packages/ssh/.ssh/42auth*
packages/ssh/.ssh/known_hosts*

# Tmux - plugins gérés par TPM au runtime
packages/terminal/.config/tmux/plugins/

# Credentials et données sensibles
packages/git/.config/gh/config.yml
packages/git/.config/gh/hosts.yml
packages/rclone/.config/rclone/rclone.conf

# Runtime / cache
*.log
*.cache
packages/editor/.vim/.netrwhist

# External binary
packages/mysh/.local/bin/oh-my-posh
packages/mysh/.local/bin/tilt