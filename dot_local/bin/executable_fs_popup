def build_css(bg_alpha=0.30, accent = "mauve", card_bg = "base"):
    (r, g, b) = (
        int(C[accent][1:3],16), int(C[accent][3:5],16), int(C[accent][5:7],16)
    )
    return f"""
    window, window.background, .transparent-bg {{
        background-color: transparent;
        background: transparent;
    }}
    .overlay-bg {{
        background-color: rgba({r}, {g}, {b}, {bg_alpha});
    }}
    #card {{
        background: {C[card_bg]};
        color: {C['text']};
        border-radius: 24px;
        padding: 36px 42px;
        box-shadow: 0 16px 64px 0 rgba(0,0,0,0.55);
        border: 1px solid {C['surface1']};
    }}
    #title {{
        font-size: 40px;
        font-weight: 700;
    }}
    #msg {{
        margin-top: 12px;
        font-size: 20px;
        color: {C['subtext1']};
    }}
    button:hover {{
        filter: brightness(1.05);
    }}
    """

# ---------------- argparse helpers ----------------
def float_0_1(v: str) -> float:
    """Parse a float between 0.0 and 1.0."""
    try:
        f = float(v)
    except ValueError:
        raise argparse.ArgumentTypeError("must be a floating-point number")
    if not (0.0 <= f <= 1.0):
        raise argparse.ArgumentTypeError("must be between 0.0 and 1.0")
    return f

def nonneg_int(v: str) -> int:
    """Parse a non-negative integer."""
    try:
        n = int(v)
    except ValueError:
        raise argparse.ArgumentTypeError("must be an integer")
    if n < 0:
        raise argparse.ArgumentTypeError("must be >= 0")
    return n

def monitor_value(v: str):
    """Parse monitor selection (all | primary | <index>)."""
    if v in ("all", "primary"):
        return v
    try:
        idx = int(v)
        if idx < 0:
            raise argparse.ArgumentTypeError("monitor index must be >= 0")
        return idx
    except ValueError:
        return "primary"

def parse_args():
    p = argparse.ArgumentParser(description="Catppuccin Mocha fullscreen popup (Adw/GTK4)")
    p.add_argument("--title", default="  Time to stop ! ")
    p.add_argument("--message", default="")
    p.add_argument("--close-btn", action="store_true", default=False)
    p.add_argument("--timeout", type=nonneg_int, default=0, help="auto-close timeout (s, 0=off)")
    p.add_argument("--snooze", type=nonneg_int, default=0, help="snooze time (s, 0=off)")
    p.add_argument("--opacity", type=float_0_1, default=0.40)
    p.add_argument("--accent", choices=list(C.keys()), default="mauve")
    p.add_argument("--card-bg", choices=list(C.keys()), default="base")
    p.add_argument("--monitor", type=monitor_value, default="all", help="all|primary|index")
    return p.parse_args()

# ---------------- monitor selection ----------------
def list_monitors(display: Gdk.Display):
    model = display.get_monitors()
    return [model.get_item(i) for i in range(model.get_n_items())]

def select_monitors(display: Gdk.Display, req):
    mons = list_monitors(display)
    if not mons:
        return [None]
    if req == "all":
        return mons
    if req == "primary":
        return [mons[0]]
    idx = int(req)
    return [mons[idx]] if 0 <= idx < len(mons) else [mons[0]]

# ---------------- main popup window ----------------
class FullscreenPopup(Gtk.ApplicationWindow):

    def __init__(self, p_args, monitor: Gdk.Monitor|None, *a, **kw):
        super().__init__(*a, **kw)

        self.monitor = monitor
        self.init_win()

        self.snooze_duration = p_args.snooze
        self.init_popup_center(p_args)

        self.init_css(p_args)

        self.set_can_target(True)
        self.root.set_can_target(True)
        self.center.set_can_target(True)

        if p_args.timeout > 0:
            GLib.timeout_add_seconds(p_args.timeout, self._timeout_close)

    def on_any_click(self, *args):
        print("CLICK ANYWHERE")

    def init_win(self):
        self.set_title("Catppuccin Mocha Popup")
        self.set_decorated(False)
        self.set_resizable(False)
        self.set_focusable(True)

        self.root = Gtk.Overlay()
        self.root.set_hexpand(True)
        self.root.set_vexpand(True)

        self.bg = Gtk.Box()
        self.bg.set_hexpand(True)
        self.bg.set_vexpand(True)
        self.bg.add_css_class('overlay-bg')
        self.root.set_child(self.bg)

        self.center = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=8)
        self.center.set_valign(Gtk.Align.CENTER)
        self.center.set_halign(Gtk.Align.CENTER)
        self.root.add_overlay(self.center)

        self.set_child(self.root)

    def init_popup_center(self, args):
        card = self.get_card_popup(args.title, args.message)
        buttons_box = self.get_buttons(args.close_btn, args.snooze > 0)
        card.append(buttons_box)
        self.center.append(card)
        
    def init_css(self, args):
        css_data = build_css(args.opacity)
        provider= Gtk.CssProvider()
        provider.load_from_data(css_data.encode())
        Gtk.StyleContext.add_provider_for_display(
            Gdk.Display.get_default(), provider, Gtk.STYLE_PROVIDER_PRIORITY_USER
        )

    def get_card_popup(self, title, message) -> Gtk.Box:
        card = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=8)
        card.set_name("card")

        title = Gtk.Label(label=title)
        title.set_wrap(True)
        title.set_justify(Gtk.Justification.CENTER)
        title.set_halign(Gtk.Align.CENTER)
        title.set_name("title")

        msg = Gtk.Label(label=message)
        msg.set_wrap(True)
        msg.set_wrap_mode(Gtk.WrapMode.WORD_CHAR)
        msg.set_justify(Gtk.Justification.CENTER)
        msg.set_halign(Gtk.Align.CENTER)
        msg.set_name("msg")

        card.append(title)
        card.append(msg)
        return card


    def get_buttons(self, has_close_btn, has_snz_btn) -> Gtk.Box:
        btn_box = Gtk.Box(spacing=8)
        btn_box.set_halign(Gtk.Align.CENTER)
        btn_box.set_valign(Gtk.Align.CENTER)

        if has_close_btn:
            close_btn = Gtk.Button(label="Dismiss")
            close_btn.connect('clicked', self.on_close_clicked)
            btn_box.append(close_btn)

        if has_snz_btn:
            snooze_btn = Gtk.Button(label=f"Snooze {self.snooze_duration//60} min")
            snooze_btn.connect('clicked', self.on_snooze_clicked)
            btn_box.append(snooze_btn)

        return btn_box

    def fullscreen_display(self, display: Gdk.Display):
        monitor = select_monitors(display, "primary")[0]
        if monitor is None:
            return
        dim = monitor.get_geometry()
        self.set_default_size(dim.width, dim.height)
        self.fullscreen()
        self.present()

    # --- Callbacks ---
    def on_close_clicked(self, _btn):
        self.close()

    def on_snooze_clicked(self, _btn):
        print(f"snooze button clicked → relaunch in {self.snooze_duration} seconds")

        self.set_visible(False)
        GLib.timeout_add_seconds(self.snooze_duration, self.reopen_popup)
        return False

    def reopen_popup(self):
        print("Snooze period finished → reopening popup")
        self.set_visible(True)
        self.present()
        return False

    def _timeout_close(self):
        self.close()
        return False

    def press(self, *_):
        print("press")

    def release(self, *_):
        print("release")

class MyApp(Adw.Application):
    def __init__(self, p_args, **kwargs):
        super().__init__(**kwargs)
        self.args = p_args
        self.connect('activate', self.on_activate)

    def on_activate(self, app):
        display = Gdk.Display.get_default()
        for mon in select_monitors(display, self.args.monitor):
            win = FullscreenPopup(self.args, mon, application=app)
            win.fullscreen_display(display)
            app.add_window(win)


# ---------------- entrypoint ----------------
def main():
    args = parse_args()
    app = MyApp(args, application_id="dev.local.fspopup.GtkApplication")
    sys.exit(app.run())

if __name__ == "__main__":
    main()

