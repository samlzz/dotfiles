#!/usr/bin/env python3
# -*- coding: utf-8 -*-

import argparse
import sys

import gi
gi.require_version('Gtk', '4.0')
gi.require_version('Adw', '1')
from gi.repository import Gtk, Gdk, Adw, GLib  # noqa: E402

Adw.init()

