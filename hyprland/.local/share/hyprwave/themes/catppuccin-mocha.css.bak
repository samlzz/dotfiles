/* HyprWave - Catppuccin Mocha Theme */
:root {
    --bg-primary: rgba(30, 30, 46, 0.75); --bg-secondary: rgba(24, 24, 37, 0.75);
    --bg-album-cover: rgba(30, 30, 46, 0.85); --bg-album-secondary: rgba(49, 50, 68, 0.85);
    --btn-default: rgba(203, 166, 247, 0.85); --btn-default-secondary: rgba(180, 190, 254, 0.85);
    --btn-default-hover: rgba(203, 166, 247, 0.95); --btn-default-hover-secondary: rgba(180, 190, 254, 0.95);
    --btn-play: rgba(245, 194, 231, 0.95); --btn-play-secondary: rgba(235, 160, 172, 0.95);
    --btn-play-hover: rgba(245, 194, 231, 1.0); --btn-play-hover-secondary: rgba(243, 139, 168, 1.0);
    --btn-play-active: rgba(235, 160, 172, 0.95); --btn-play-active-secondary: rgba(235, 160, 172, 0.85);
    --btn-expand: rgba(137, 220, 235, 0.95); --btn-expand-secondary: rgba(116, 199, 236, 0.95);
    --btn-expand-hover: rgba(148, 226, 213, 0.98); --btn-expand-hover-secondary: rgba(137, 220, 235, 0.98);
    --btn-expand-active: rgba(116, 199, 236, 0.95); --btn-expand-active-secondary: rgba(116, 199, 236, 0.85);
    --progress-bg: rgba(49, 50, 68, 0.25); --progress-fill-start: rgba(245, 194, 231, 0.95); --progress-fill-end: rgba(137, 220, 235, 0.95);
    --handle-color: rgba(203, 166, 247, 0.98); --handle-hover: rgba(203, 166, 247, 1.0);
    --handle-border: rgba(180, 190, 254, 0.5); --handle-shadow: rgba(203, 166, 247, 0.7);
    --text-primary: rgba(205, 214, 244, 0.95); --text-secondary: rgba(186, 194, 222, 0.85);
    --text-tertiary: rgba(166, 173, 200, 0.75); --text-muted: rgba(147, 153, 178, 0.65);
    --border-primary: rgba(88, 91, 112, 0.35); --border-button: rgba(69, 71, 90, 0.3);
    --border-button-hover: rgba(88, 91, 112, 0.45); --border-play: rgba(245, 194, 231, 0.4);
    --border-play-hover: rgba(245, 194, 231, 0.55); --border-expand: rgba(137, 220, 235, 0.4);
    --border-expand-hover: rgba(137, 220, 235, 0.55); --shadow-default: rgba(17, 17, 27, 0.6);
    --shadow-button: rgba(17, 17, 27, 0.5); --shadow-play: rgba(245, 194, 231, 0.6);
    --shadow-play-hover: rgba(245, 194, 231, 0.8); --shadow-expand: rgba(137, 220, 235, 0.5);
    --shadow-expand-hover: rgba(137, 220, 235, 0.7); --shadow-focus: rgba(203, 166, 247, 0.8);
    --border-radius-container: 100px; --border-radius-section: 20px; --border-radius-album: 16px;
    --border-radius-button: 50%; --border-radius-progress: 2px; --padding-container: 12px; --padding-section: 16px;
}
.visualizer-bar {
    background: linear-gradient(180deg, rgba(245, 194, 231, 0.98), rgba(203, 166, 247, 0.98), rgba(137, 220, 235, 0.98));
    border-radius: 0px; transition: all 0.05s ease-out; margin: 0px; min-width: 1px; min-height: 3px;
    box-shadow: 0 0 16px rgba(203, 166, 247, 0.8), 0 0 10px rgba(137, 220, 235, 0.6);
}
.vertical-display-label { font-family: 'VT323', monospace; font-size: 28px; font-weight: bold;
    color: rgba(203, 166, 247, 0.98); letter-spacing: 0px; line-height: 1.2; }
